PORT=5000
MONGODB_URI=mongodb://localhost:27017/property-db
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
NODE_ENV=development

# Optional: Hostinger FTP upload settings
HOSTINGER_FTP_HOST=
HOSTINGER_FTP_PORT=21
HOSTINGER_FTP_USERNAME=
HOSTINGER_FTP_PASSWORD=
HOSTINGER_FTP_REMOTE_PATH=/domains/your-domain.com/nodejs/uploads
HOSTINGER_FTP_MIRROR_PATH=/domains/your-domain.com/public_html/uploads
HOSTINGER_PUBLIC_URL=https://your-domain.com/uploads
