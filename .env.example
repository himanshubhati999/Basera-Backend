PORT=5000
MONGODB_URI=mongodb://localhost:27017/property-db
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
NODE_ENV=development

# OTP email sender (required for signup/verify OTP flow)
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Basera Infra Home

# Cloudinary image storage (required for /api/upload routes)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=basera

# Optional: comma-separated list of exact frontend origins
# Example: https://your-frontend.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=
